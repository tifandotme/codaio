{
  "name": "codaio",
  "version": "0.3.0",
  "description": "CLI for the Coda API v1",
  "type": "module",
  "bin": {
    "codaio": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun build src/index.ts --outfile dist/cli.js --target node --format esm --banner '#!/usr/bin/env node' && chmod +x dist/cli.js",
    "changeset": "changeset",
    "dev": "bun run src/index.ts",
    "generate:types": "bunx openapi-typescript https://coda.io/apis/v1/openapi.json -o src/types/openapi.d.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@types/bun": "latest",
    "openapi-typescript": "^7.0.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "coda",
    "coda.io",
    "cli",
    "api"
  ],
  "license": "MIT"
}
